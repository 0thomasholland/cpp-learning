{
  "lsp": {
    "clangd": {
      "binary": {
        "arguments": [
          "--background-index",
          "--clang-tidy",
          "--completion-style=detailed",
          "--function-arg-placeholders=0",
          "--header-insertion=iwyu",
          "--pch-storage=memory",
        ],
      },
    },
  },
  "languages": {
    "C++": {
      "format_on_save": "on",
      "tab_size": 4,
    },
  },
}
